# Copy to .harpoon.env in the same folder as main.py (values are examples).
# Harpoon loads .harpoon.env automatically before reading config — no need to export in the shell each time.

# Use bundled wordlists under harpoon/wordlists/ instead of system SecLists
HARPOON_USE_BUNDLED_WORDLISTS=1

# If you have SecLists installed, point to the real directory (not a placeholder path):
# HARPOON_SECLISTS_DIR=/usr/share/seclists

# Put Go and pip --user tools on PATH when you run main.py directly:
# (scripts/run_harpoon.sh adds these for you)
# PATH is not set here by default — use run_harpoon.sh or add to your shell profile.
